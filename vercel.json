{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/feedback", "destination": "/api/index.py" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/script.js", "destination": "/public/script.js" },
    { "source": "/clients.json", "destination": "/public/clients.json" },
    { "source": "/assets/(.*)", "destination": "/public/assets/$1" }
  ]
}
